MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/bakery_db?retryWrites=true&w=majority
PORT=5000

# JWT for all auth (customer, employee, admin)
JWT_SECRET=your_super_secret_key_min_32_chars_long
JWT_EXPIRES=7d

# Optional: seed first admin (run once: node scripts/seedAdmin.js)
# ADMIN_EMAIL=admin@bakery.com
# ADMIN_PASSWORD=your_admin_password
